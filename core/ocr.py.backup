def run_ocr(img_path=None, save_result=False, rois=None):
    ram_call = _begin_ram_call(
        kind="ocr",
        context="run_ocr",
        request_name=os.path.basename(img_path) if img_path else "screen_capture",
        meta={
            "save_result": bool(save_result),
            "rois_count": len(rois) if rois else 0,
            "img_path_provided": bool(img_path),
        },
    )

    #Printing the OCR result a bit beautifully
    def print_ocr_results(results):
        if not results:
            print("No OCR results found.")
            return

        print("\n" + "="*70)
        print(f"{'TEXT':<25} | {'SCORE':<6} | {'BOX'}")
        print("="*70)

        for res in results:
            text = res["text"][:25]  # trim long text
            score = f"{res['score']:.2f}"
            box = res["box"]

            print(f"{text:<25} | {score:<6} | {box}")

        print("="*70 + "\n")

    #A function to add extra padding around the rois, OCR always fail for tiny image    
    def add_padding(img, pad=50):
        h, w, k = img.shape
        avg_color = img.mean(axis=(0, 1))
        new_img = np.full((h + 2*pad, w + 2*pad, k), avg_color, dtype=img.dtype)
        new_img[pad:pad+h, pad:pad+w] = img
        return new_img, pad
    _enforce_ram_cap("run_ocr:start")

    try:
        img = _capture_frame(img_path)
    except Exception as e:
        print(f"Error - {e}")
        _end_ram_call(ram_call, outcome="capture_error", error=str(e), result_count=0)
        return []

    if img is None:
        _end_ram_call(ram_call, outcome="no_image", result_count=0)
        return []

    _log_call_input_fingerprint(
        ram_call,
        image=img,
        rois=rois,
        extra={
            "img_path_provided": bool(img_path),
            "save_result": bool(save_result),
            "pad_px": 50,
        },
    )

    all_results = []
    h, w = img.shape[:2]
    
    # Ensure debug directory exists if saving
    if save_result and not os.path.exists("test/debug"):
        os.makedirs("test/debug", exist_ok=True)

    if rois:
        tt = 0
        for i, roi in enumerate(rois):
            roi = clamp_roi(roi, w, h) 
            if not roi:
                continue

            x1, y1, x2, y2 = roi
            # Only pad if the crop actually has dimensions
            raw_crop = img[y1:y2, x1:x2]
            if raw_crop.size == 0:
                continue
                
            cropped, pad_val = add_padding(raw_crop, pad=50)

            t1 = time.time()
            output = _call_ocr_with_recovery(cropped)
            t2 = time.time()
            tt += t2-t1
            
            if not output or not output[0]:
                # If save_result is true, save the empty crop to see what OCR saw
                if save_result:
                    cv2.imwrite(f"test/debug/roi_empty_{int(time.time())}_{i}.png", cropped)
                continue
                
            lines = output[0]
            offset_x = x1 - pad_val
            offset_y = y1 - pad_val

            for line in lines:
                if not line or not isinstance(line, list) or len(line) < 2:
                    continue

                pts = np.array(line[0])
                text = line[1][0]
                score = float(line[1][1])

                if score > 0.8:
                    xmin = int(pts[:, 0].min())
                    ymin = int(pts[:, 1].min())
                    xmax = int(pts[:, 0].max())
                    ymax = int(pts[:, 1].max())

                    all_results.append({
                        "text": text,
                        "score": score,
                        "box": [
                            xmin + offset_x, 
                            ymin + offset_y, 
                            xmax + offset_x, 
                            ymax + offset_y
                        ]
                    })
            
            if save_result:
                # Save the specific crop being processed
                cv2.imwrite(f"test/debug/roi_crop_{int(time.time())}_{i}.png", cropped)

    else:
        t1 = time.time()
        output = _call_ocr_with_recovery(img)
        t2 = time.time()
        tt = t2 - t1
        if output and output[0]:
            for line in output[0]:
                if not line: continue
                
                pts = np.array(line[0])
                text = line[1][0]
                score = float(line[1][1])

                if score > 0.8:
                    xmin = int(pts[:, 0].min())
                    ymin = int(pts[:, 1].min())
                    xmax = int(pts[:, 0].max())
                    ymax = int(pts[:, 1].max())

                    all_results.append({
                        "text": text,
                        "score": score,
                        "box": [xmin, ymin, xmax, ymax]
                    })

    # 👉 SAVE FULL RESULT IMAGE
    if save_result and all_results:
        debug_img = img.copy()
        for res in all_results:
            b = res["box"]
            # Draw rectangle: (xmin, ymin), (xmax, ymax)
            cv2.rectangle(debug_img, (int(b[0]), int(b[1])), (int(b[2]), int(b[3])), (0, 255, 0), 2)
            cv2.putText(debug_img, res["text"], (int(b[0]), int(b[1]) - 10), 
                        cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0, 255, 0), 1)
        
        cv2.imwrite(f"test/debug/full_res_{int(time.time())}.png", debug_img)

    print_ocr_results(all_results)
    print(f"({tt} s)")
    _enforce_ram_cap("run_ocr:end")

    _end_ram_call(ram_call, outcome="ok", result_count=len(all_results))
    return all_results


@app.post("/ocr")
def ocr_endpoint(req:OCRRequest):
    try:
        results = run_ocr(req.img_path, req.save_result, req.rois)
    except MemoryError as e:
        return {
            "success": False,
            "count": 0,
            "results": None,
            "error": str(e),
        }

    if results is None:
        return{
            "success" : False,
            "results" : None
        }

    return {
        "success" : True,
        "count" : len(results),
        "results" : results
    }


@app.post("/template")
def template_matching(req:TemplateMatchRequest):
    try:
        _enforce_ram_cap("template:start")
        results = match_template(
            name=req.name,
            threshold=req.threshold,
            save_result=req.save_result,
            rois=req.rois,
            parallel=req.parallel,
            session_id=req.session_id,
        )
        _enforce_ram_cap("template:end")
    except MemoryError as e:
        return {
            "success": False,
            "results": None,
            "error": str(e),
        }

    if results is None:
        return{
            "success" : False,
            "results" : None
        }

    return {
        "success" : True,
        "results" : results
    }


@app.post("/clear_cache")
def _clear_session_cache(req:ClearCacheRequest):
    with _cache_lock:
        _cache.pop(req.session_id, None)



init_services()

if __name__ == "__main__":
    uvicorn.run(
        app,
        host="127.0.0.1",
        port=8000
    )